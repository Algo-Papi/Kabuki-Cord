NHI_ZUES_PROFILE_DIR=.profiles/nhi-zues
NHI_ZUES_BROWSER_CHANNEL=chrome
NHI_ZUES_STATE_DIR=.state
NHI_ZUES_SERVERS_FILE=config/servers.json
NHI_ZUES_CHARACTER_DIR=character_cards
NHI_ZUES_CHARACTER_CARD=default.json
NHI_ZUES_DRY_RUN=true
NHI_ZUES_HEADLESS=false
NHI_ZUES_SCANNER_MAX_CHANNELS_PER_CYCLE=1
NHI_ZUES_SCANNER_CYCLE_SLEEP_SECONDS=45
NHI_ZUES_SCANNER_CHANNEL_SETTLE_SECONDS=12
NHI_ZUES_SCANNER_MIN_CHANNEL_DELAY_SECONDS=12
NHI_ZUES_SCANNER_MAX_CHANNEL_DELAY_SECONDS=35

# Auto-send safety guardrails. Manual approval sends still require the operator.
NHI_ZUES_REPLY_COOLDOWN_SECONDS=900
NHI_ZUES_REPLY_WINDOW_SECONDS=3600
NHI_ZUES_REPLY_MAX_PER_WINDOW=3
NHI_ZUES_REPLY_REQUIRE_INTERVENING_USER=true

# Format: server_id:channel_id,channel_id;server_id:channel_id
# Used only when NHI_ZUES_SERVERS_FILE is missing or empty.
NHI_ZUES_CHANNELS=

# Optional. Without this, the runner logs decisions but does not generate model replies.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# API spend controls. Dry-run message sending is separate from draft generation.
NHI_ZUES_LLM_ENABLED=false
NHI_ZUES_DRAFT_IN_DRY_RUN=false
NHI_ZUES_MAX_DAILY_USD=0.25
NHI_ZUES_MAX_SESSION_USD=0.05
NHI_ZUES_MAX_LLM_CALLS_PER_RUN=3
NHI_ZUES_MAX_OUTPUT_TOKENS=120
NHI_ZUES_MAX_INPUT_CHARS=6000

# Proactive/topic-only drafts are queued for user review instead of sent directly.
NHI_ZUES_PROACTIVE_APPROVAL_REQUIRED=true

# Human-style writing imperfections applied to generated drafts.
NHI_ZUES_WRITING_MISTAKE_RATE=0.06
NHI_ZUES_WRITING_QUIRK=lowercase_no_commas
NHI_ZUES_WRITING_MISSPELLINGS=definitely:definately,because:becuase,probably:prolly

# Emoji reactions can run on observed channels with React enabled, even when Engage is off.
# Dry Mode still blocks all Discord writes. The cap applies per channel scan.
NHI_ZUES_REACTION_MAX_PER_CHANNEL=3
NHI_ZUES_REACTION_THRESHOLD=normal
NHI_ZUES_REACTION_SAMPLE_PERCENT=0
NHI_ZUES_REACTION_FORCE_LAUGH_PERCENT=20
NHI_ZUES_REACTION_EMOJI_OVERRIDE=

# Live sends can be typed into Discord over time so the normal typing indicator appears.
NHI_ZUES_TYPING_INDICATOR_ENABLED=true
NHI_ZUES_TYPING_MIN_SECONDS=2.5
NHI_ZUES_TYPING_MAX_SECONDS=18.0
NHI_ZUES_TYPING_CHARS_PER_SECOND=10.0
